# Neon Postgres connection string
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Bearer token ที่ extension ต้องส่งมาใน /api/ingest (สุ่มเองให้ยาว ๆ)
INGEST_TOKEN="change-me-to-a-long-random-string"

# Secret ที่ Vercel Cron ใช้เรียก /api/cron/daily (Vercel ตั้งให้อัตโนมัติเมื่อ deploy)
CRON_SECRET="change-me-too"
