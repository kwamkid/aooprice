{
  "manifest_version": 3,
  "name": "aooprice — Price Monitor (Shopee/TikTok/Lazada)",
  "version": "0.2.0",
  "description": "ดึงราคา/ยอดขาย/เรตติ้งสินค้า Shopee / TikTok Shop / Lazada ตาม keyword แล้วส่งเข้า aooprice dashboard",
  "permissions": ["alarms", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://shopee.co.th/*",
    "https://*.shopee.co.th/*",
    "https://*.tiktok.com/*",
    "https://*.lazada.co.th/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://shopee.co.th/*",
        "https://*.tiktok.com/*",
        "https://*.lazada.co.th/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "aooprice"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/shopee-api.js",
        "lib/tiktok-api.js",
        "lib/lazada-api.js",
        "config.js"
      ],
      "matches": [
        "https://shopee.co.th/*",
        "https://*.tiktok.com/*",
        "https://*.lazada.co.th/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
